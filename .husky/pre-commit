#!/usr/bin/env sh

# Run ESLint on staged src files
npx lint-staged || exit 1

# Type-check whole project
npx tsc --noEmit || exit 1

# Block forbidden patterns in staged additions.
# We only look at added lines (+) and only match JS/TS comment syntax
# (// or /* prefix) so shell-script comments in this file don't trigger.

STAGED_ADDITIONS=$(git diff --cached --unified=0 -- '*.ts' '*.tsx' | grep "^+" | grep -v "^+++" || true)

FAILED=0

# Block new JS/TS eslint-disable comments except the allowed exhaustive-deps form
FORBIDDEN_DISABLE=$(echo "$STAGED_ADDITIONS" \
  | grep -E "//\s*eslint-disable|/\*\s*eslint-disable" \
  | grep -vE "react-hooks/exhaustive-deps" || true)

if [ -n "$FORBIDDEN_DISABLE" ]; then
  echo ""
  echo "Pre-commit blocked: eslint-disable comment added to staged files."
  echo "Fix the underlying lint error instead of suppressing it."
  echo "(eslint-disable-next-line react-hooks/exhaustive-deps is the only allowed form)"
  echo ""
  FAILED=1
fi

# Block new ': any' type annotations
if echo "$STAGED_ADDITIONS" | grep -qE ": any[,\) ;|>]|: any$"; then
  echo ""
  echo "Pre-commit blocked: ': any' type annotation added to staged files."
  echo "Provide a proper type, or use 'unknown' + a type guard."
  echo ""
  FAILED=1
fi

exit $FAILED
