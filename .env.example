# ── Supabase (browser-safe) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-only — never expose to browser) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Broker sync ────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting broker tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TRADR_ENCRYPTION_KEY=64-hex-chars-here

# Random secret sent by Vercel Cron as x-cron-secret header.
# Must match the value in vercel.json cron → headers.
CRON_SECRET=your-random-secret-here

# Tradovate API credentials (get from developer.tradovate.com)
TRADOVATE_APP_ID=your-app-id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your-cid
TRADOVATE_SEC=your-sec-secret

# ── Feedback bot ───────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# ── Stripe billing ─────────────────────────────────────────────────────────────
# Use sk_test_... for local dev / staging; sk_live_... for production only.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly and annual recurring prices (GBP). Create in Stripe Dashboard → Products.
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
# Legacy single-price var — still accepted as monthly fallback.
STRIPE_PRICE_ID=price_...
# The Stripe "promotion code" object ID (promo_xxx) for the K0DA beta code.
# Create coupon (100% off, forever) → create promotion code K0DA → copy promo_xxx here.
STRIPE_PROMO_CODE_ID_K0DA=promo_...

# ── Analytics ─────────────────────────────────────────────────────────────────
# PostHog — leave blank to disable.
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ── Error monitoring ──────────────────────────────────────────────────────────
# Optional — leave blank to disable Sentry.
# To enable: npm install @sentry/react
VITE_SENTRY_DSN=

# ── Beta access wall ──────────────────────────────────────────────────────────
# If set, shows a password gate before auth. Leave blank to disable.
VITE_BETA_PASSWORD=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:dnyland420@gmail.com
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
