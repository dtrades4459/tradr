# ── Supabase (browser-safe) ────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Supabase (server-only — never expose to browser) ──────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App URL ────────────────────────────────────────────────────────────────────
# Production URL used in emails, Stripe redirects, and CORS origin lists.
APP_URL=https://kodatrade.co.uk

# ── Supabase (server-only — anon key for user-context API calls) ───────────────
# Distinct from SUPABASE_SERVICE_ROLE_KEY — used when acting as the user, not admin.
SUPABASE_ANON_KEY=your-anon-key-here

# ── Broker sync ────────────────────────────────────────────────────────────────
# AES-256-GCM key for encrypting broker tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KODA_ENCRYPTION_KEY=64-hex-chars-here

# Random secret sent by Vercel Cron as x-cron-secret header.
# Must match the value in vercel.json cron → headers.
CRON_SECRET=your-random-secret-here

# Tradovate API credentials (get from developer.tradovate.com)
TRADOVATE_APP_ID=your-app-id
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your-cid
TRADOVATE_SEC=your-sec-secret

# ── Feedback bot (announcement pushes to users) ────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id
# Secret token set when registering the webhook with Telegram.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ── Businesstats bot (internal ops metrics) ────────────────────────────────────
# Bot token from @BotFather for @businesstats_bot.
TELEGRAM_BUSINESSTATS_TOKEN=your-businesstats-bot-token
# Webhook secret — generate the same way as TELEGRAM_WEBHOOK_SECRET above.
TELEGRAM_BUSINESSTATS_SECRET=your-businesstats-webhook-secret
# Comma-separated Telegram user IDs allowed to use the bot (Dylon, Bruno, Dan).
TELEGRAM_ALLOWED_USER_IDS=7587404723,1711954101,1918389515
# ID of the private ops group chat where the daily digest is posted.
# Negative number for group chats (e.g. -5275164414).
TELEGRAM_OPS_CHAT_ID=-5275164414

# ── Stripe billing ─────────────────────────────────────────────────────────────
# Use sk_test_... for local dev / staging; sk_live_... for production only.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Monthly and annual recurring prices (GBP). Create in Stripe Dashboard → Products.
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_ANNUAL=price_...
# Legacy single-price var — still accepted as monthly fallback.
STRIPE_PRICE_ID=price_...
# Stripe promotion code object IDs (promo_xxx). Create in Stripe Dashboard → Coupons.
STRIPE_PROMO_CODE_ID_K0DA=promo_...
STRIPE_PROMO_CODE_ID_FOUNDERS=promo_...
STRIPE_PROMO_CODE_ID_BETA=promo_...

# ── Analytics ─────────────────────────────────────────────────────────────────
# PostHog — leave blank to disable.
VITE_POSTHOG_KEY=phc_...
VITE_POSTHOG_HOST=https://eu.i.posthog.com
# Server-side PostHog key for businesstats bot (different from browser key).
# Create at posthog.com → Settings → Personal API keys.
POSTHOG_PERSONAL_API_KEY=phx_...
# Numeric project ID from posthog.com → Settings → Project.
POSTHOG_PROJECT_ID=12345

# ── Error monitoring ──────────────────────────────────────────────────────────
# Optional — leave blank to disable Sentry.
# To enable: npm install @sentry/react
VITE_SENTRY_DSN=
# App version string injected into Sentry releases. Typically set by CI (e.g. git SHA).
VITE_APP_VERSION=
# Server-side Sentry credentials for businesstats bot error reporting.
# Token: sentry.io → Settings → Auth Tokens → Create token (scope: project:read, org:read).
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=koda-tt
# Project slug from sentry.io → Settings → Projects.
SENTRY_PROJECT=your-sentry-project-slug

# ── Beta access wall ──────────────────────────────────────────────────────────
# If set, shows a password gate before auth. Leave blank to disable.
VITE_BETA_PASSWORD=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:you@example.com
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key
